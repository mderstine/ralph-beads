# Purser environment variables
# Copy to .env and customize. These override .purser.yml values.

# GitHub integration
# PURSER_GITHUB_HOST=github.com
# PURSER_GITHUB_REMOTE=origin
# PURSER_GITHUB_OWNER=
# PURSER_GITHUB_REPO=
# PURSER_GITHUB_AUTO_CREATE=prompt    # prompt | skip | auto
# PURSER_GITHUB_PROJECT_NUMBER=

# Labels
# PURSER_LABELS_BOOTSTRAP=false

# Loop
# PURSER_TIMEOUT=120                  # seconds per iteration

# Logging
# PURSER_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
